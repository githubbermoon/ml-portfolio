---
import FloraGate from "../islands/FloraGate";
const base = import.meta.env.BASE_URL;
const { showStudio = false } = Astro.props;
const isRealmsMode = import.meta.env.SITE_MODE === "realms";
---

{isRealmsMode ? (
  <footer class="section-shell py-10 text-center text-[10px] uppercase tracking-[0.28em] text-mist/35">
    <p>© 2026 Pranjal Prakash</p>
  </footer>
) : (
  <footer class="relative mt-20 min-h-[30vh] flex items-end overflow-hidden">
    {
      !showStudio && (
        <div class="footer-still-scene absolute inset-0 z-0 pointer-events-none" aria-hidden="true">
          <div class="footer-orbit"></div>
          <div class="footer-bloom">
            <span class="footer-petal footer-petal-1"></span>
            <span class="footer-petal footer-petal-2"></span>
            <span class="footer-petal footer-petal-3"></span>
            <span class="footer-petal footer-petal-4"></span>
            <span class="footer-petal footer-petal-5"></span>
            <span class="footer-petal footer-petal-6"></span>
            <span class="footer-petal footer-petal-7"></span>
            <span class="footer-petal footer-petal-8"></span>
            <span class="footer-flower-core"></span>
          </div>
          <div class="footer-grass"></div>
        </div>
      )
    }
    {!showStudio && <FloraGate client:visible />}

    <div class="section-shell relative z-10 w-full pb-12">
      <div class="grid gap-10 md:grid-cols-[2fr_1fr] items-end">
        <div class="space-y-4">
          <p class="text-2xl font-semibold text-glass md:text-3xl">
            Pranjal Prakash
          </p>
          <p class="text-sm uppercase tracking-[0.2em] text-mist">
            ML + CV portfolio
          </p>
          <div></div>
          <div class="pt-2">
            <a
              class="text-xs uppercase tracking-[0.25em] text-mist/70 transition hover:text-white"
              href={base + "pranjal-cv.pdf"}
              download
            >
              Download CV
            </a>
          </div>
        </div>

        <div
          class="flex flex-col gap-2 text-xs uppercase tracking-[0.3em] text-mist md:text-right"
        >
          <span>Bengaluru, India</span>
        </div>
      </div>
      <div class="relative mt-12 pt-6 border-t border-white/5">
        <div
          class="absolute inset-0 -z-10 bg-gradient-to-t from-black via-black/80 to-transparent blur-xl scale-125 transform-gpu opacity-80 pointer-events-none"
        >
        </div>

        <div
          class="flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] uppercase tracking-[0.25em] text-mist/40 font-medium"
        >
          <p>© 2026 Pranjal Prakash</p>
          <div class="flex items-center gap-6">
            <span>V 2.0.1</span>
          </div>
        </div>
      </div>
    </div>
  </footer>
)}
