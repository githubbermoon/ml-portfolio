---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const base = import.meta.env.BASE_URL;
const isRealmsMode = import.meta.env.SITE_MODE === 'realms';
---

<BaseLayout
	title={isRealmsMode ? "Projects | Ancient Sciences Builds" : "Projects | Pranjal Prakash ML Portfolio"}
	description={isRealmsMode
		? "Future Realms projects inspired by ancient sciences, symbolic systems, and practical tools."
		: "Selected machine learning projects and case studies by Pranjal Prakash, including terrain safety analysis, computer vision, FastAPI backends, and reproducible ML systems."}
	tags={isRealmsMode
		? ["ancient sciences", "Vedic sciences", "projects", "Realms"]
		: ["machine learning projects", "computer vision", "FastAPI", "PyTorch", "ML portfolio"]}
>
	<Nav />
	<main class="section-shell">
		{isRealmsMode ? (
			<>
				<h1 class="text-4xl md:text-5xl">Ancient Sciences Projects</h1>
				<p class="mt-4 max-w-2xl text-mist">
					This page will hold projects and prototypes built around Vedic sciences,
					symbolic systems, traditional knowledge, and practical tools.
				</p>
				<div class="mt-10 grid gap-6 md:grid-cols-2">
					<article class="glass-panel p-6">
						<p class="text-sm text-mist">Coming soon</p>
						<h2 class="mt-3 text-2xl text-glass">Vedic sciences tools</h2>
						<p class="mt-3 text-mist">
							Future calculators, visualizations, diagrams, and research interfaces will live here.
						</p>
					</article>
					<article class="glass-panel p-6">
						<p class="text-sm text-mist">Direction</p>
						<h2 class="mt-3 text-2xl text-glass">Ancient knowledge × software</h2>
						<p class="mt-3 text-mist">
							A separate project surface for Realms, not the professional GitHub Pages portfolio.
						</p>
					</article>
				</div>
			</>
		) : (
			<>
				<h1 class="text-4xl md:text-5xl">Projects</h1>
				<p class="mt-4 max-w-2xl text-mist">
					Case studies, demos, and ML experiments with measurable outcomes.
				</p>
				<div class="mt-10 grid gap-6 md:grid-cols-2">
					{projects.map((project) => (
						<article class="glass-panel p-6">
							<p class="text-sm text-mist">{project.data.tags.join(' / ')}</p>
							<h2 class="mt-3 text-2xl text-glass">{project.data.title}</h2>
							<p class="mt-3 text-mist">{project.data.summary}</p>
							<a class="mt-4 inline-block text-sm text-glow" href={base + 'projects/' + project.slug + '/'}>Read case study</a>
						</article>
					))}
				</div>
			</>
		)}
	</main>
	<Footer />
</BaseLayout>
