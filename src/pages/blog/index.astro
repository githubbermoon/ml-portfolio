---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const base = import.meta.env.BASE_URL;
const realms = [
	{
		name: "Mechanica",
		label: "Technical",
		href: "blog/technical/",
		description: "ML systems, computer vision notes, benchmarks, code, and reproducible experiments.",
		symbol: "01",
	},
	{
		name: "Ananta Nīhāra",
		label: "Spiritual / speculative",
		href: "blog/ananta-nihara/",
		description: "Perception, intelligence, inner experience, mythic language, and visual essays.",
		symbol: "∞",
	},
	{
		name: "Jyotiṣa",
		label: "Astrology",
		href: "blog/astrology/",
		description: "Planetary notes, symbolic systems, timing, archetypes, and chart reflections.",
		symbol: "☉",
	},
	{
		name: "Rasam",
		label: "Cooking",
		href: "blog/cooking/",
		description: "Recipes, kitchen systems, taste experiments, food memory, and process notes.",
		symbol: "♨",
	},
	{
		name: "Field Notes",
		label: "Essays",
		href: "blog/essays/",
		description: "Personal essays, observations, reading notes, and unfinished thoughts worth preserving.",
		symbol: "✦",
	},
	{
		name: "Index",
		label: "Reference",
		href: "blog/notes/",
		description: "Short notes, glossary entries, links, fragments, and reusable knowledge blocks.",
		symbol: "⌁",
	},
];
---

<BaseLayout
	title="Realms Blog | ML Notes, Essays & Field Archive"
	description="Realms is Pranjal Prakash's living archive for ML notes, computer vision writing, symbolic systems, essays, astrology fragments, cooking logs, and reference notes."
	tags={["ML blog", "technical writing", "computer vision notes", "essays", "Realms"]}
>
	<Nav />
	<main class="section-shell">
		<section class="library-hero">
			<p class="text-xs uppercase tracking-[0.35em] text-mist">Private library</p>
			<h1 class="mt-5 max-w-4xl text-5xl md:text-7xl">A field guide for machines, myths, stars, and kitchens</h1>
			<p class="mt-6 max-w-2xl text-lg leading-8 text-mist">
				A living archive for technical work and inner-world research: ML notes, spiritual essays, astrology fragments,
				cooking experiments, and reference entries that connect over time.
			</p>
		</section>

		<div class="library-realm-grid mt-12">
			{realms.map((realm) => (
				<a class="library-realm-card" href={base + realm.href}>
					<span class="library-realm-symbol">{realm.symbol}</span>
					<span class="text-xs uppercase tracking-[0.24em] text-mist">{realm.label}</span>
					<h2 class="mt-4 text-3xl text-glass">{realm.name}</h2>
					<p class="mt-4 text-sm leading-6 text-mist">{realm.description}</p>
					<span class="mt-6 inline-flex text-sm text-glow">Enter realm →</span>
				</a>
			))}
		</div>

		<section class="mt-16">
			<div class="flex flex-col justify-between gap-4 border-t border-white/10 pt-8 md:flex-row md:items-end">
				<div>
					<p class="text-xs uppercase tracking-[0.24em] text-mist">Latest entries</p>
					<h2 class="mt-3 text-3xl text-glass">Recently opened pages</h2>
				</div>
				<p class="max-w-md text-sm leading-6 text-mist">
					This area will become searchable once the archive grows. For now, it keeps the current MDX posts visible.
				</p>
			</div>
		</section>

		<div class="mt-8 grid gap-6">
			{posts.map((post) => (
				<article class="glass-panel p-6">
					<p class="text-sm text-mist">{post.data.realm ?? post.data.tags.join(' / ')}</p>
					<h2 class="mt-3 text-2xl text-glass">{post.data.title}</h2>
					<p class="mt-3 text-mist">{post.data.summary}</p>
					<a class="mt-4 inline-block text-sm text-glow" href={base + 'blog/' + post.slug + '/'}>Read post</a>
				</article>
			))}
		</div>
	</main>
	<Footer />
</BaseLayout>
