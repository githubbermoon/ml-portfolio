    },
    lock: {
      title: "Checksum lock",
      body: "The final bundle fixes manifests and SHA-256 records so the reported run can be audited after publication.",
      stat: "5/5",
      label: "gate score",
      artifact: "checksum bundle",
      related: ["shap", "modis"],
    },
  };

  const setMethodStep = (step: string) => {
    const detail = methodDetails[step];
    if (!detail) return;

    methodNodes?.forEach((node) => {
      const nodeStep = node.dataset.step ?? "";
      node.classList.toggle("is-active", nodeStep === step);
      node.classList.toggle("is-related", detail.related.includes(nodeStep));
    });

    methodEdges?.forEach((edge) => {
      const edgeSteps = edge.dataset.edge?.split(" ") ?? [];
      edge.classList.toggle("is-active", edgeSteps.includes(step));
    });

    if (methodTitle) methodTitle.textContent = detail.title;
    if (methodBody) methodBody.textContent = detail.body;
    if (methodStat) methodStat.textContent = detail.stat;
    if (methodLabel) methodLabel.textContent = detail.label;
    if (methodArtifact) methodArtifact.textContent = detail.artifact;
  };

  methodNodes?.forEach((node) => {
    const step = node.dataset.step ?? "";
    node.addEventListener("mouseenter", () => setMethodStep(step));
    node.addEventListener("focus", () => setMethodStep(step));
    node.addEventListener("click", () => setMethodStep(step));
    node.addEventListener("keydown", (event) => {
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        setMethodStep(step);
      }
    });
  });
</script>

