---
import "../styles/global.css";
import Spotlight from "../islands/Spotlight";
import ThemeToggle from "../islands/ThemeToggle";
import AnalyticsHotkey from "../islands/AnalyticsHotkey";

const {
  title = "Pranjal Prakash | ML Portfolio & Realms",
  description = "Machine learning portfolio and Realms archive by Pranjal Prakash: computer vision projects, ML systems, technical writing, and immersive field notes.",
  bodyClass,
  image = "/ananta-nihara-hero.png",
  type = "website",
  noindex = false,
  publishedDate,
  modifiedDate,
  tags = [],
} = Astro.props;
const base = import.meta.env.BASE_URL;
const isRealmsMode = import.meta.env.SITE_MODE === "realms";
const isRealmsInnerPage = isRealmsMode && Astro.url.pathname !== "/";
const goatCounterCode = import.meta.env.PUBLIC_GOATCOUNTER_CODE;
const siteOrigin = (Astro.site ?? new URL(isRealmsMode ? "https://realms-58q.pages.dev" : "https://githubbermoon.github.io")).toString();
const normalizedBase = base.endsWith("/") ? base : `${base}/`;
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const imagePath = image.startsWith("http")
  ? image
  : image.startsWith(normalizedBase)
    ? image
    : image.startsWith("/")
      ? `${normalizedBase}${image.slice(1)}`
      : `${normalizedBase}${image}`;
const imageUrl = new URL(imagePath, siteOrigin).toString();
const siteName = isRealmsMode ? "Realms by Pranjal Prakash" : "Pranjal Prakash | Machine Learning Portfolio";
const ogImageAlt = isRealmsMode
  ? "Realms: cinematic writing archive by Pranjal Prakash"
  : "Pranjal Prakash machine learning portfolio and technical writing";
const blogPassword = import.meta.env.PUBLIC_BLOG_PASSWORD ?? "open";
const blogPrefix = `${normalizedBase}blog`;
const devBlogPrefix = "/blog";
const publicBlogPrefix = isRealmsMode ? "__professional_public_blog__" : `${blogPrefix}/uhi-bengaluru`;
const publicDevBlogPrefix = isRealmsMode ? "__professional_public_blog_dev__" : `${devBlogPrefix}/uhi-bengaluru`;
const isPublicBlogRoute =
  Astro.url.pathname.startsWith(publicBlogPrefix) ||
  Astro.url.pathname.startsWith(publicDevBlogPrefix);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": type === "article" ? "Article" : "WebSite",
  name: title,
  headline: title,
  description,
  url: canonicalUrl,
  image: imageUrl,
  author: {
    "@type": "Person",
    name: "Pranjal Prakash",
    url: siteOrigin,
    sameAs: [
      "https://github.com/githubbermoon",
      "https://linkedin.com/in/pranjal-prakash",
    ],
  },
  ...(publishedDate ? { datePublished: publishedDate } : {}),
  ...(modifiedDate ? { dateModified: modifiedDate } : {}),
  ...(tags.length ? { keywords: tags.join(", ") } : {}),
};
const isBlogRoute =
  isRealmsMode &&
  !isPublicBlogRoute &&
  (Astro.url.pathname.startsWith(blogPrefix) ||
    Astro.url.pathname.startsWith(devBlogPrefix));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {tags.length > 0 && <meta name="keywords" content={tags.join(", ")} />}
    {noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow, max-image-preview:large" />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" type="application/xml" href={base + "sitemap.xml"} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#050505" />
    <meta name="author" content="Pranjal Prakash" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:creator" content="@githubbermoon" />
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}
    {modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}
    {tags.map((tag: string) => <meta property="article:tag" content={tag} />)}
    <link rel="icon" type="image/png" href={base + (isRealmsMode ? "favicon-realms.png" : "favicon.svg")} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <slot name="head" />
    <script is:inline define:vars={{ blogPassword, blogPrefix, devBlogPrefix, publicBlogPrefix, publicDevBlogPrefix }}>
      const storedTheme = localStorage.getItem("clawd-theme");
      const prefersLight = window.matchMedia(
        "(prefers-color-scheme: light)",
      ).matches;
      const resolvedTheme =
        storedTheme === "bright" || storedTheme === "dark"
          ? storedTheme
          : prefersLight
            ? "bright"
            : "dark";
      document.documentElement.dataset.theme = resolvedTheme;
      const storedFilm = localStorage.getItem("clawd-film");
      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;
      const prefersContrast = window.matchMedia(
        "(prefers-contrast: more)",
      ).matches;
      const filmEnabled =
        !prefersReduced &&
        !prefersContrast &&
        (storedFilm === "on"
          ? true
          : storedFilm === "off"
            ? false
            : resolvedTheme !== "bright");
      document.documentElement.dataset.film = filmEnabled ? "on" : "off";

      window.addEventListener("cut-to-project", () => {
        document.body.classList.add("warp-active");
      });

      const BLOG_PASSWORD = blogPassword;
      const BLOG_KEY = "blog-gate-until";
      const isPublicBlogRoute =
        window.location.pathname.startsWith(publicBlogPrefix) ||
        window.location.pathname.startsWith(publicDevBlogPrefix);
      const isBlogRoute =
        !isPublicBlogRoute &&
        (window.location.pathname.startsWith(blogPrefix) ||
          window.location.pathname.startsWith(devBlogPrefix));
      if (isBlogRoute) {
        const until = sessionStorage.getItem(BLOG_KEY);
        const unlocked = until && Number(until) > Date.now();
        document.addEventListener("DOMContentLoaded", () => {
          const gate = document.getElementById("blog-gate");
          const form = document.getElementById("blog-gate-form");
          const input = document.getElementById("blog-gate-input");
          const error = document.getElementById("blog-gate-error");
          if (unlocked) {
            document.documentElement.classList.remove("blog-locked");
            if (gate) gate.classList.remove("is-visible");
            return;
          }
          document.documentElement.classList.add("blog-locked");
          if (gate) gate.classList.add("is-visible");
          form?.addEventListener("submit", (event) => {
            event.preventDefault();
            if (!input) return;
            if (input.value !== BLOG_PASSWORD) {
              if (error) error.textContent = "Incorrect password";
              return;
            }
            if (error) error.textContent = "";
            const next = Date.now() + 12 * 60 * 60 * 1000;
            sessionStorage.setItem(BLOG_KEY, String(next));
            document.documentElement.classList.remove("blog-locked");
            if (gate) gate.classList.remove("is-visible");
          });
        });
      }
    </script>
    {!isRealmsMode && goatCounterCode && (
      <script
        data-goatcounter={`https://${goatCounterCode}.goatcounter.com/count`}
        async
        src="//gc.zgo.at/count.js"
      ></script>
    )}
    <title>{title}</title>
  </head>
  <body class:list={[bodyClass, isBlogRoute && "blog-locked"]}>
    {isRealmsInnerPage && (
      <a
        href={base}
        aria-label="Back to Realms home"
        class="fixed left-8 top-8 z-[100] text-sm uppercase tracking-[0.2em] text-slate-700 transition hover:text-slate-950"
      >
        ← Index
      </a>
    )}
    
    {isRealmsInnerPage && (
      <div class="fixed top-8 right-8 z-[100] text-right font-mono text-[10px] uppercase tracking-[0.2em] text-slate-600">
        <p>32.0005° N, 77.4815° E</p>
      </div>
    )}
    {!isRealmsInnerPage && (
      <div class="fixed top-6 right-6 z-[100] pointer-events-auto">
        <ThemeToggle client:load />
      </div>
    )}
    <Spotlight client:load />
    <slot />
    {!isRealmsMode && <AnalyticsHotkey client:load goatCounterCode={goatCounterCode} />}
    {isRealmsMode && (
      <div
        id="blog-gate"
        class:list={["blog-gate", isBlogRoute && "is-visible"]}
        aria-hidden={!isBlogRoute}
      >
        <div class="blog-gate-card">
          <p class="text-xs uppercase tracking-[0.3em] text-mist">Private</p>
          <h2 class="mt-3 text-2xl text-glass">Enter password</h2>
          <form id="blog-gate-form" class="mt-6 flex flex-col gap-3">
            <input
              id="blog-gate-input"
              class="rounded-full border border-mist/30 bg-glass/5 px-4 py-3 text-sm text-glass placeholder:text-mist/70"
              type="password"
              autocomplete="current-password"
              placeholder="Password"
            />
            <button
              type="submit"
              class="rounded-full border border-mist/40 px-4 py-3 text-sm text-glass transition hover:border-glass/50"
            >
              Unlock
            </button>
          </form>
          <p id="blog-gate-error" class="mt-3 text-xs text-amber-400"></p>
        </div>
      </div>
    )}
    <svg
      aria-hidden="true"
      focusable="false"
      width="0"
      height="0"
      style="position:absolute; width:0; height:0; overflow:hidden;"
    >
      <filter
        id="liquid-hero-filter"
        x="-40%"
        y="-40%"
        width="180%"
        height="180%"
        color-interpolation-filters="sRGB"
      >
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.008 0.02"
          numOctaves="2"
          seed="8"
          result="noise"></feTurbulence>
        <feDisplacementMap
          id="liquid-hero-displacement"
          in="SourceGraphic"
          in2="noise"
          scale="0"
          xChannelSelector="R"
          yChannelSelector="G"></feDisplacementMap>
      </filter>
    </svg>
    <div class="film-overlay" aria-hidden="true">
      <div class="film-grain"></div>
      <div class="film-vignette"></div>
    </div>
  </body>
</html>

<style>
  :global(.blog-locked body > :not(#blog-gate)) {
    display: none !important;
  }
  :global(.blog-gate) {
    position: fixed;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    background: #000;
    z-index: 9999;
  }
  :global(.blog-gate.is-visible) {
    display: flex;
  }
  :global(.blog-gate-card) {
    width: min(90vw, 420px);
  }
</style>
