---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

const base = import.meta.env.BASE_URL;

const isRealmsMode = import.meta.env.SITE_MODE === "realms";
if (!isRealmsMode) return Astro.redirect("/ml-portfolio/blog/");
---

<BaseLayout title="Field Notes | Clawd ML Portfolio">
  <Nav />
  <main class="section-shell field-notes-shell">
    <section class="field-notes-hero">
      <div class="field-notes-copy">
        <a class="text-xs uppercase tracking-[0.28em] text-mist" href={base + "blog/"}>Back to library</a>
        <p class="mt-10 text-xs uppercase tracking-[0.35em] text-mist">Essays</p>
        <h1 class="mt-5 max-w-4xl text-5xl md:text-7xl">Field Notes</h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-mist">
          Personal essays, reading notes, observations, and unfinished thoughts. This realm is for slower writing that
          does not need to fit into a technical or ritual category.
        </p>
      </div>
      <figure class="storm-light-frame" aria-label="Mountain storm with light beams">
        <img
          class="storm-light-bleed"
          src={base + "images/atmosphere/storm-light.webp"}
          alt=""
          loading="eager"
          decoding="async"
          aria-hidden="true"
        />
        <img
          class="storm-light-image"
          src={base + "images/atmosphere/storm-light.webp"}
          alt="Golden storm clouds sending shafts of light over a mountain valley."
          loading="eager"
          decoding="async"
        />
      </figure>
    </section>
    <section class="mt-12 grid gap-6 md:grid-cols-3">
      <article class="glass-panel p-6">
        <p class="text-xs uppercase tracking-[0.24em] text-mist">Format</p>
        <h2 class="mt-4 text-2xl text-glass">Long essays</h2>
        <p class="mt-3 text-sm leading-6 text-mist">Polished arguments with references and durable URLs.</p>
      </article>
      <a class="glass-panel reading-notes-card md:col-span-3" href={base + "blog/reading-notes/fear/"}>
        <img
          class="reading-notes-cover"
          src={base + "images/atmosphere/reading-notes-cover-hq.webp"}
          alt=""
          loading="lazy"
          decoding="async"
          aria-hidden="true"
        />
        <div class="reading-notes-copy p-6">
          <p class="text-xs uppercase tracking-[0.24em] text-mist">Format</p>
          <h2 class="mt-4 text-2xl text-glass">Reading notes</h2>
          <p class="mt-3 text-sm leading-6 text-mist">Short summaries, quotes, links, and personal annotations.</p>
          <p class="mt-6 text-xs uppercase tracking-[0.24em] text-glass">Open note: Fear</p>
        </div>
      </a>
      <article class="glass-panel p-6">
        <p class="text-xs uppercase tracking-[0.24em] text-mist">Format</p>
        <h2 class="mt-4 text-2xl text-glass">Fragments</h2>
        <p class="mt-3 text-sm leading-6 text-mist">Half-formed ideas worth keeping visible for later synthesis.</p>
      </article>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .field-notes-shell {
    overflow: hidden;
  }

  .field-notes-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(280px, 0.72fr);
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
  }

  .field-notes-copy {
    position: relative;
    z-index: 2;
    min-width: 0;
  }

  .storm-light-frame {
    position: relative;
    overflow: visible;
    height: clamp(20rem, 38vw, 34rem);
    margin: 0;
    border-radius: 1.75rem;
    isolation: isolate;
  }

  .storm-light-frame::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    border-radius: inherit;
    background:
      linear-gradient(to top, rgb(var(--color-ink) / 0.42), transparent 45%),
      radial-gradient(circle at 58% 24%, rgb(245 158 11 / 0.16), transparent 38%);
    pointer-events: none;
  }

  .storm-light-image {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 52% 45%;
    border: 1px solid rgb(var(--color-glass) / 0.12);
    border-radius: inherit;
    box-shadow: 0 28px 80px rgb(0 0 0 / 0.26);
    filter: saturate(1.03) contrast(1.05);
  }

  .storm-light-bleed {
    position: absolute;
    top: -16%;
    left: -28%;
    z-index: -1;
    width: 158%;
    max-width: none;
    height: 134%;
    object-fit: cover;
    object-position: 52% 45%;
    border-radius: 3rem;
    opacity: 0.17;
    filter: blur(28px) saturate(1.04) contrast(1.08);
    mask-image: radial-gradient(ellipse at 58% 46%, black 0 34%, rgb(0 0 0 / 0.7) 48%, transparent 72%);
  }

  .reading-notes-card {
    position: relative;
    display: block;
    min-height: clamp(18rem, 30vw, 28rem);
    overflow: hidden;
    isolation: isolate;
    text-decoration: none;
    transition:
      border-color 180ms ease,
      transform 180ms ease;
  }

  .reading-notes-card:hover {
    border-color: rgb(var(--color-glass) / 0.26);
    transform: translateY(-2px);
  }

  .reading-notes-card::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(90deg, rgb(8 12 18 / 0.84) 0%, rgb(8 12 18 / 0.52) 42%, rgb(8 12 18 / 0.12) 100%),
      linear-gradient(to top, rgb(8 12 18 / 0.72), transparent 58%);
    pointer-events: none;
  }

  .reading-notes-cover {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    width: 100%;
    max-width: none;
    height: 100%;
    object-fit: cover;
    object-position: 50% 48%;
    filter: saturate(1.04) contrast(1.06);
  }

  .reading-notes-copy {
    position: relative;
    z-index: 2;
    max-width: 30rem;
  }

  .reading-notes-copy h2,
  .reading-notes-copy p {
    color: rgb(248 250 252);
    text-shadow: 0 2px 22px rgb(0 0 0 / 0.72);
  }

  [data-theme="bright"] .storm-light-frame {
    filter: none;
  }

  [data-theme="bright"] .storm-light-image {
    box-shadow: 0 22px 54px rgb(15 23 42 / 0.12);
  }

  [data-theme="bright"] .storm-light-bleed {
    opacity: 0.14;
    mix-blend-mode: multiply;
  }

  [data-theme="bright"] .reading-notes-card::after {
    background:
      linear-gradient(90deg, rgb(15 23 42 / 0.78) 0%, rgb(15 23 42 / 0.48) 42%, rgb(15 23 42 / 0.1) 100%),
      linear-gradient(to top, rgb(15 23 42 / 0.52), transparent 58%);
  }

  @media (max-width: 860px) {
    .field-notes-hero {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .storm-light-frame {
      height: 20rem;
      border-radius: 1.35rem;
    }

    .storm-light-bleed {
      left: -10%;
      width: 120%;
      opacity: 0.16;
    }
  }
</style>
