---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL;
const realms = [
	{
		name: "Vedic Sciences",
		label: "Technical Work",
		href: "technical-work/",
		description: "Structured notes and experiments around ancient sciences, symbolic systems, and computation.",
		symbol: "01",
	},
	{
		name: "Ananta Nīhāra",
		label: "Spiritual / speculative",
		href: "blog/ananta-nihara/",
		description: "Perception, intelligence, inner experience, mythic language, and visual essays.",
		symbol: "∞",
	},
	{
		name: "Jyotiṣa",
		label: "Astrology",
		href: "blog/astrology/",
		description: "Planetary notes, symbolic systems, timing, archetypes, and chart reflections.",
		symbol: "☉",
	},
	{
		name: "Rasam",
		label: "Cooking",
		href: "blog/cooking/",
		description: "Recipes, kitchen systems, taste experiments, food memory, and process notes.",
		symbol: "♨",
	},
	{
		name: "Field Notes",
		label: "Essays",
		href: "blog/essays/",
		description: "Personal essays, observations, reading notes, and unfinished thoughts worth preserving.",
		symbol: "✦",
	},
	{
		name: "Index",
		label: "Reference",
		href: "blog/notes/",
		description: "Short notes, glossary entries, links, fragments, and reusable knowledge blocks.",
		symbol: "⌁",
	},
];
---

<BaseLayout
	title="Kosh (कोश) | Realms Archive"
	description="Kosh means a treasury or library. This Realms archive holds notes, references, essays, fragments, and future work on Vedic sciences and symbolic systems."
	tags={["Kosh", "Realms", "Vedic sciences", "symbolic systems", "archive"]}
>
	<Nav />
	<main class="mx-auto max-w-6xl px-8 md:px-20 py-20 bg-[#fdfcfb] text-[#1a1a1a]">
		<header class="mb-24 flex flex-col md:flex-row gap-12 border-b border-gray-200 pb-20">
			<div class="flex-1">
				<h1 class="text-6xl font-serif tracking-tight mb-8">Kosh (कोश)</h1>
				<p class="text-lg text-gray-600 leading-relaxed max-w-md">
					A treasury of notes, references, essays, fragments, and field notes.
				</p>
			</div>
			<div class="border-l border-gray-200 pl-12 flex flex-col justify-between">
                <img src={base + "images/atmosphere/ritual-water.webp"} class="h-24 w-24 object-cover rounded-sm opacity-90" alt="" />
                <div class="text-sm text-gray-500 gap-4 font-mono">
    				<div>
    					<p class="uppercase text-[10px] tracking-[0.2em] font-semibold text-gray-400">Context</p>
    					<p>Living Archive</p>
    				</div>
    			</div>
            </div>
		</header>

		<section class="grid md:grid-cols-2 gap-24 mb-24">
            <div class="space-y-12">
                {realms.slice(0, 3).map((realm) => (
                    <a class="group cursor-pointer block" href={base + realm.href}>
                        <p class="font-mono text-[10px] uppercase tracking-widest text-gray-400 mb-2">{realm.label}</p>
                        <h2 class="text-2xl font-bold mb-2 group-hover:underline">{realm.name}</h2>
                        <p class="text-gray-600 text-sm leading-6">{realm.description}</p>
                    </a>
                ))}
            </div>

            <div class="border-l border-gray-200 pl-12 space-y-12">
                {realms.slice(3).map((realm) => (
                    <a class="group cursor-pointer block" href={base + realm.href}>
                        <p class="font-mono text-[10px] uppercase tracking-widest text-gray-400 mb-2">{realm.label}</p>
                        <h2 class="text-2xl font-bold mb-2 group-hover:underline">{realm.name}</h2>
                        <p class="text-gray-600 text-sm leading-6">{realm.description}</p>
                    </a>
                ))}
            </div>
		</section>

	</main>
	<Footer />
</BaseLayout>

<style>
	:global(body) {
		background: #fdfcfb;
		color: #1a1a1a;
	}

	:global([data-theme="dark"]) body {
		background: #fdfcfb;
		color: #1a1a1a;
	}

	:global([data-theme="dark"]) .text-gray-700,
	:global([data-theme="dark"]) .text-gray-600,
	:global([data-theme="dark"]) .text-gray-500,
	:global([data-theme="dark"]) .text-gray-400 {
		color: inherit;
		opacity: 0.72;
	}
</style>
